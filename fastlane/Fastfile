fastlane_version "2.235.0"

default_platform :ios

platform :ios do
  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      mode: :lint,
      strict: true,
      raise_if_swiftlint_error: true
    )
  end

  desc "Run unit and UI tests"
  lane :test do
    run_tests(
      scheme: "CountThat",
      devices: ["iPhone 16"],
      clean: true,
      result_bundle: true
    )
  end

  desc "One-time local setup: generate certs and push to certs repo using ASC API key"
  lane :match_init do
    setup_asc_api_key
    match(type: "appstore", readonly: false)
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_asc_api_key

    match(type: "appstore", readonly: true)

    increment_build_number(
      build_number: latest_testflight_build_number + 1
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "CountThat.xcodeproj",
      team_id: ENV["TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.1conundrum.CountThat",
      profile_name: "match AppStore com.1conundrum.CountThat"
    )

    build_app(
      scheme: "CountThat",
      export_method: "app-store",
      clean: true
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  desc "Submit to App Store"
  lane :release do
    setup_asc_api_key

    match(type: "appstore", readonly: true)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "CountThat.xcodeproj",
      team_id: ENV["TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.1conundrum.CountThat",
      profile_name: "match AppStore com.1conundrum.CountThat"
    )

    build_app(
      scheme: "CountThat",
      export_method: "app-store",
      clean: true
    )

    upload_to_app_store(
      submit_for_review: true,
      automatic_release: false,
      force: true
    )
  end

  private_lane :setup_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )
  end
end
