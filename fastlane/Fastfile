fastlane_version "2.235.0"

default_platform :ios

platform :ios do
  desc "Run SwiftLint"
  lane :lint do
    swiftlint(
      mode: :lint,
      strict: true,
      raise_if_swiftlint_error: true
    )
  end

  desc "Run unit and UI tests"
  lane :test do
    run_tests(
      scheme: "CountThat",
      devices: ["iPhone 16"],
      clean: true,
      result_bundle: true
    )
  end

  desc "Capture App Store screenshots (run locally before submission)"
  lane :screenshots do
    capture_screenshots(only_testing: ["CountThatUITests/CountThatSnapshotTests"])

    screenshots_dir = File.join(File.dirname(__FILE__), "screenshots")
    Dir.glob(File.join(screenshots_dir, "**", "*.png")).each do |path|
      renamed = path.gsub(" ", "_")
      File.rename(path, renamed) if renamed != path
    end
  end

  desc "One-time local setup: generate certs and push to certs repo using ASC API key"
  lane :match_init do
    setup_asc_api_key
    match(type: "appstore", readonly: false)
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    verify_app_icon
    verify_info_plist

    setup_asc_api_key
    setup_ci_keychain

    match(
      type: "appstore",
      readonly: true,
      keychain_name: ENV["CI_KEYCHAIN_NAME"],
      keychain_password: ENV["CI_KEYCHAIN_PASSWORD"]
    )

    increment_build_number(
      build_number: latest_testflight_build_number + 1
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "CountThat.xcodeproj",
      team_id: ENV["TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.1conundrum.CountThat",
      profile_name: "match AppStore com.1conundrum.CountThat"
    )

    build_app(
      scheme: "CountThat",
      export_method: "app-store",
      clean: true
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  ensure
    delete_keychain(name: ENV["CI_KEYCHAIN_NAME"]) if ENV["CI_KEYCHAIN_NAME"]
  end

  desc "Submit to App Store"
  lane :release do
    verify_app_icon
    verify_info_plist

    version = ENV["GITHUB_REF_NAME"]&.delete_prefix("v")
    increment_version_number(version_number: version) if version

    setup_asc_api_key
    setup_ci_keychain

    match(
      type: "appstore",
      readonly: true,
      keychain_name: ENV["CI_KEYCHAIN_NAME"],
      keychain_password: ENV["CI_KEYCHAIN_PASSWORD"]
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "CountThat.xcodeproj",
      team_id: ENV["TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: "com.1conundrum.CountThat",
      profile_name: "match AppStore com.1conundrum.CountThat"
    )

    build_app(
      scheme: "CountThat",
      export_method: "app-store",
      clean: true
    )

    upload_to_app_store(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      overwrite_screenshots: true
    )
  ensure
    delete_keychain(name: ENV["CI_KEYCHAIN_NAME"]) if ENV["CI_KEYCHAIN_NAME"]
  end

  private_lane :setup_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false,
      in_house: false
    )
  end

  private_lane :setup_ci_keychain do
    keychain_name = "ci_signing_#{SecureRandom.hex(4)}"
    keychain_password = SecureRandom.hex(32)

    ENV["CI_KEYCHAIN_NAME"] = keychain_name
    ENV["CI_KEYCHAIN_PASSWORD"] = keychain_password

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )
  end
end
